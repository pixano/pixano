---
/**
 * Callout/Admonition — Hyper-Glass treatment with retro-futurist styling.
 *
 * Usage:
 *   <Callout type="tip" title="Optional Title">Content here</Callout>
 *   <Callout type="note" title="Title" collapsible>Collapsible content</Callout>
 */

interface Props {
  type?: "note" | "tip" | "warning" | "danger" | "info" | "success";
  title?: string;
  collapsible?: boolean;
}

const { type = "note", title, collapsible = false } = Astro.props;

const icons: Record<string, string> = {
  note: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  tip: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>`,
  warning: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  danger: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
  info: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`,
  success: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
};

const defaultTitles: Record<string, string> = {
  note: "Note",
  tip: "Tip",
  warning: "Warning",
  danger: "Danger",
  info: "Info",
  success: "Success",
};

const displayTitle = title || defaultTitles[type];
const icon = icons[type];
const Tag = collapsible ? "details" : "div";
---

{collapsible ? (
  <details class={`callout callout-${type}`}>
    <summary class="callout-header">
      <span class="callout-icon" set:html={icon} />
      <span class="callout-title">{displayTitle}</span>
      <svg class="callout-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </summary>
    <div class="callout-content">
      <slot />
    </div>
  </details>
) : (
  <div class={`callout callout-${type}`}>
    <div class="callout-header">
      <span class="callout-icon" set:html={icon} />
      <span class="callout-title">{displayTitle}</span>
    </div>
    <div class="callout-content">
      <slot />
    </div>
  </div>
)}

<style>
  /* ── Hyper-Glass Callout ── */
  .callout {
    border-radius: var(--px-radius-lg);
    border: 1px solid var(--px-glass-border);
    border-left: 4px solid;
    margin: 1.5rem 0;
    overflow: hidden;
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
    box-shadow: var(--px-glass-shadow-inset);
    transition:
      box-shadow 200ms ease,
      border-color 200ms ease;
  }

  .callout:hover {
    box-shadow:
      var(--px-shadow),
      var(--px-glass-shadow-inset);
  }

  /* Type colors — translucent backgrounds */
  .callout-note {
    border-left-color: var(--px-note);
    background: var(--px-note-bg);
  }
  .callout-tip {
    border-left-color: var(--px-tip);
    background: var(--px-tip-bg);
  }
  .callout-warning {
    border-left-color: var(--px-warning);
    background: var(--px-warning-bg);
  }
  .callout-danger {
    border-left-color: var(--px-danger);
    background: var(--px-danger-bg);
  }
  .callout-info {
    border-left-color: var(--px-info);
    background: var(--px-info-bg);
  }
  .callout-success {
    border-left-color: var(--px-success);
    background: var(--px-success-bg);
  }

  /* Header */
  .callout-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-weight: 600;
    font-family: var(--px-font-ui);
    font-size: 0.825rem;
    cursor: default;
    letter-spacing: 0.01em;
  }

  details .callout-header {
    cursor: pointer;
    user-select: none;
  }

  details .callout-header:hover {
    opacity: 0.85;
  }

  /* Icon colors */
  .callout-note .callout-icon { color: var(--px-note); }
  .callout-tip .callout-icon { color: var(--px-tip); }
  .callout-warning .callout-icon { color: var(--px-warning); }
  .callout-danger .callout-icon { color: var(--px-danger); }
  .callout-info .callout-icon { color: var(--px-info); }
  .callout-success .callout-icon { color: var(--px-success); }

  .callout-title {
    color: var(--px-text);
  }

  .callout-note .callout-title { color: var(--px-note); }
  .callout-tip .callout-title { color: var(--px-tip); }
  .callout-warning .callout-title { color: var(--px-warning); }
  .callout-danger .callout-title { color: var(--px-danger); }
  .callout-info .callout-title { color: var(--px-info); }
  .callout-success .callout-title { color: var(--px-success); }

  /* Chevron for collapsible */
  .callout-chevron {
    margin-left: auto;
    transition: transform 200ms ease;
    opacity: 0.6;
  }

  details[open] .callout-chevron {
    transform: rotate(180deg);
  }

  /* Content */
  .callout-content {
    padding: 0 1rem 0.75rem;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .callout-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout-content :global(pre) {
    margin: 0.75rem 0;
  }

  /* Remove default details marker */
  details summary {
    list-style: none;
  }

  details summary::-webkit-details-marker {
    display: none;
  }
</style>
